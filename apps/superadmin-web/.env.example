# VisionDesk Superadmin Web - Environment Variables
# Copy this file to .env.local for development or .env.production for production

# ===========================================
# API URL
# ===========================================
# Development: Leave empty to use Vite proxy (/api)
# Production: Full URL to API server
VITE_API_URL=

# Examples:
# Development (uses proxy): VITE_API_URL=
# Production: VITE_API_URL=https://api.visiondesk.ma/api
