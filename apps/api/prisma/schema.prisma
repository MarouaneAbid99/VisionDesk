generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  SUPERADMIN
  OWNER
  ADMIN
  OPTICIAN
  TECHNICIAN
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  IN_ATELIER
  READY
  READY_FOR_PICKUP
  PICKED_UP
  DELIVERED
  CANCELLED
}

enum AtelierJobStatus {
  PENDING
  IN_PROGRESS
  BLOCKED
  READY
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
  RETURN
}

enum LensType {
  SINGLE_VISION
  BIFOCAL
  PROGRESSIVE
  READING
  SUNGLASSES
}

enum LensCoating {
  NONE
  ANTI_REFLECTIVE
  BLUE_LIGHT
  PHOTOCHROMIC
  POLARIZED
  SCRATCH_RESISTANT
}

enum AppointmentType {
  EYE_EXAM
  CONTACT_LENS
  PICKUP
  REPAIR
  OTHER
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
}

// ============================================
// CORE ENTITIES
// ============================================

model Shop {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(255)
  address   String?  @db.VarChar(500)
  phone     String?  @db.VarChar(50)
  email     String?  @db.VarChar(255)
  logo      String?  @db.VarChar(500)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users           User[]
  clients         Client[]
  suppliers       Supplier[]
  frameBrands     FrameBrand[]
  frames          Frame[]
  lenses          Lens[]
  orders          Order[]
  atelierJobs     AtelierJob[]
  stockMovements  StockMovement[]
  panoramaScenes  PanoramaScene[]
  activityLogs    ActivityLog[]
  appSettings     AppSetting[]
  appointments    Appointment[]
  payments        Payment[]

  @@map("shops")
}

model User {
  id           String   @id @default(uuid())
  shopId       String   @map("shop_id")
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  firstName    String   @map("first_name") @db.VarChar(100)
  lastName     String   @map("last_name") @db.VarChar(100)
  role         UserRole @default(OPTICIAN)
  phone        String?  @db.VarChar(50)
  avatar       String?  @db.VarChar(500)
  isActive     Boolean  @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  shop                  Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  atelierJobs           AtelierJob[]  @relation("AssignedTechnician")
  createdOrders         Order[]       @relation("OrderCreatedBy")
  activityLogs          ActivityLog[]
  createdAppointments   Appointment[] @relation("AppointmentCreatedBy")
  createdPayments       Payment[]     @relation("PaymentCreatedBy")

  @@index([shopId])
  @@index([email])
  @@map("users")
}

model Client {
  id          String   @id @default(uuid())
  shopId      String   @map("shop_id")
  firstName   String   @map("first_name") @db.VarChar(100)
  lastName    String   @map("last_name") @db.VarChar(100)
  email       String?  @db.VarChar(255)
  phone       String?  @db.VarChar(50)
  address     String?  @db.VarChar(500)
  dateOfBirth DateTime? @map("date_of_birth") @db.Date
  notes       String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  shop          Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  prescriptions Prescription[]
  orders        Order[]
  appointments  Appointment[]

  @@index([shopId])
  @@index([shopId, isActive])
  @@index([lastName, firstName])
  @@index([phone])
  @@index([email])
  @@map("clients")
}

model Prescription {
  id        String   @id @default(uuid())
  clientId  String   @map("client_id")
  
  // Right eye (OD - Oculus Dexter)
  odSph     Decimal? @map("od_sph") @db.Decimal(5, 2)
  odCyl     Decimal? @map("od_cyl") @db.Decimal(5, 2)
  odAxis    Int?     @map("od_axis")
  odAdd     Decimal? @map("od_add") @db.Decimal(4, 2)
  
  // Left eye (OS - Oculus Sinister)
  osSph     Decimal? @map("os_sph") @db.Decimal(5, 2)
  osCyl     Decimal? @map("os_cyl") @db.Decimal(5, 2)
  osAxis    Int?     @map("os_axis")
  osAdd     Decimal? @map("os_add") @db.Decimal(4, 2)
  
  // Pupillary distance
  pdFar     Decimal? @map("pd_far") @db.Decimal(4, 1)
  pdNear    Decimal? @map("pd_near") @db.Decimal(4, 1)
  
  doctorName String? @map("doctor_name") @db.VarChar(255)
  notes      String? @db.Text
  expiresAt  DateTime? @map("expires_at") @db.Date
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  client Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([clientId])
  @@map("prescriptions")
}

model Supplier {
  id        String   @id @default(uuid())
  shopId    String   @map("shop_id")
  name      String   @db.VarChar(255)
  contact   String?  @db.VarChar(255)
  email     String?  @db.VarChar(255)
  phone     String?  @db.VarChar(50)
  address   String?  @db.VarChar(500)
  notes     String?  @db.Text
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  shop   Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  frames Frame[]
  lenses Lens[]

  @@index([shopId])
  @@map("suppliers")
}

model FrameBrand {
  id        String   @id @default(uuid())
  shopId    String   @map("shop_id")
  name      String   @db.VarChar(255)
  logo      String?  @db.VarChar(500)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  shop   Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  frames Frame[]

  @@index([shopId])
  @@map("frame_brands")
}

model Frame {
  id            String   @id @default(uuid())
  shopId        String   @map("shop_id")
  brandId       String?  @map("brand_id")
  supplierId    String?  @map("supplier_id")
  reference     String   @db.VarChar(100)
  model         String?  @db.VarChar(255)
  color         String?  @db.VarChar(100)
  size          String?  @db.VarChar(50)
  material      String?  @db.VarChar(100)
  quantity      Int      @default(0)
  reorderLevel  Int      @default(5) @map("reorder_level")
  purchasePrice Decimal  @default(0) @map("purchase_price") @db.Decimal(10, 2)
  salePrice     Decimal  @default(0) @map("sale_price") @db.Decimal(10, 2)
  barcode       String?  @db.VarChar(100)
  image         String?  @db.VarChar(500)
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  shop           Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  brand          FrameBrand?     @relation(fields: [brandId], references: [id], onDelete: SetNull)
  supplier       Supplier?       @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  orders         Order[]
  stockMovements StockMovement[]

  @@index([shopId])
  @@index([shopId, isActive])
  @@index([brandId])
  @@index([supplierId])
  @@index([reference])
  @@map("frames")
}

model Lens {
  id            String      @id @default(uuid())
  shopId        String      @map("shop_id")
  supplierId    String?     @map("supplier_id")
  name          String      @db.VarChar(255)
  lensType      LensType    @default(SINGLE_VISION) @map("lens_type")
  index         String?     @db.VarChar(20)
  coating       LensCoating @default(NONE)
  quantity      Int         @default(0)
  reorderLevel  Int         @default(5) @map("reorder_level")
  purchasePrice Decimal     @default(0) @map("purchase_price") @db.Decimal(10, 2)
  salePrice     Decimal     @default(0) @map("sale_price") @db.Decimal(10, 2)
  barcode       String?     @db.VarChar(100)
  minSphere     Decimal?    @map("min_sphere") @db.Decimal(5, 2)
  maxSphere     Decimal?    @map("max_sphere") @db.Decimal(5, 2)
  minCylinder   Decimal?    @map("min_cylinder") @db.Decimal(5, 2)
  maxCylinder   Decimal?    @map("max_cylinder") @db.Decimal(5, 2)
  maxAdd        Decimal?    @map("max_add") @db.Decimal(4, 2)
  isActive      Boolean     @default(true) @map("is_active")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  shop           Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  supplier       Supplier?       @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  orders         Order[]
  stockMovements StockMovement[]

  @@index([shopId])
  @@index([shopId, isActive])
  @@index([supplierId])
  @@map("lenses")
}

model Order {
  id             String        @id @default(uuid())
  shopId         String        @map("shop_id")
  clientId       String        @map("client_id")
  prescriptionId String?       @map("prescription_id")
  frameId        String?       @map("frame_id")
  lensId         String?       @map("lens_id")
  createdById    String        @map("created_by_id")
  orderNumber    String        @unique @map("order_number") @db.VarChar(50)
  status         OrderStatus   @default(DRAFT)
  paymentStatus  PaymentStatus @default(UNPAID) @map("payment_status")
  framePrice     Decimal       @default(0) @map("frame_price") @db.Decimal(10, 2)
  lensPrice      Decimal       @default(0) @map("lens_price") @db.Decimal(10, 2)
  servicePrice   Decimal       @default(0) @map("service_price") @db.Decimal(10, 2)
  discount       Decimal       @default(0) @db.Decimal(10, 2)
  deposit        Decimal       @default(0) @db.Decimal(10, 2)
  totalPrice     Decimal       @default(0) @map("total_price") @db.Decimal(10, 2)
  paidAt         DateTime?     @map("paid_at")
  notes          String?       @db.Text
  dueDate        DateTime?     @map("due_date") @db.Date
  readyAt        DateTime?     @map("ready_at")
  pickedUpAt     DateTime?     @map("picked_up_at")
  deliveredAt    DateTime?     @map("delivered_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  shop         Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  client       Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  prescription Prescription? @relation(fields: [prescriptionId], references: [id], onDelete: SetNull)
  frame        Frame?        @relation(fields: [frameId], references: [id], onDelete: SetNull)
  lens         Lens?         @relation(fields: [lensId], references: [id], onDelete: SetNull)
  createdBy    User          @relation("OrderCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  atelierJob   AtelierJob?
  payments     Payment[]

  @@index([shopId])
  @@index([shopId, status])
  @@index([shopId, createdAt])
  @@index([shopId, paymentStatus])
  @@index([clientId])
  @@index([status])
  @@index([paymentStatus])
  @@index([orderNumber])
  @@index([createdAt])
  @@index([dueDate])
  @@map("orders")
}

model AtelierJob {
  id              String           @id @default(uuid())
  shopId          String           @map("shop_id")
  orderId         String           @unique @map("order_id")
  technicianId    String?          @map("technician_id")
  status          AtelierJobStatus @default(PENDING)
  priority        Int              @default(0)
  dueDate         DateTime?        @map("due_date") @db.Date
  blockedReason   String?          @map("blocked_reason") @db.VarChar(255)
  notes           String?          @db.Text
  technicianNotes String?          @map("technician_notes") @db.Text
  startedAt       DateTime?        @map("started_at")
  completedAt     DateTime?        @map("completed_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  shop       Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  order      Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  technician User?  @relation("AssignedTechnician", fields: [technicianId], references: [id], onDelete: SetNull)

  @@index([shopId])
  @@index([shopId, status])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@map("atelier_jobs")
}

model StockMovement {
  id          String            @id @default(uuid())
  shopId      String            @map("shop_id")
  frameId     String?           @map("frame_id")
  lensId      String?           @map("lens_id")
  type        StockMovementType
  quantity    Int
  reason      String?           @db.VarChar(255)
  reference   String?           @db.VarChar(100)
  createdAt   DateTime          @default(now()) @map("created_at")

  shop  Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  frame Frame? @relation(fields: [frameId], references: [id], onDelete: SetNull)
  lens  Lens?  @relation(fields: [lensId], references: [id], onDelete: SetNull)

  @@index([shopId])
  @@index([frameId])
  @@index([lensId])
  @@index([createdAt])
  @@map("stock_movements")
}

model Payment {
  id          String   @id @default(uuid())
  shopId      String   @map("shop_id")
  orderId     String   @map("order_id")
  amount      Decimal  @db.Decimal(10, 2)
  method      String?  @db.VarChar(50)
  reference   String?  @db.VarChar(100)
  notes       String?  @db.Text
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  shop      Shop  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  order     Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdBy User  @relation("PaymentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([shopId])
  @@index([orderId])
  @@index([createdAt])
  @@map("payments")
}

// ============================================
// APPOINTMENTS
// ============================================

model Appointment {
  id              String            @id @default(uuid())
  shopId          String            @map("shop_id")
  clientId        String            @map("client_id")
  createdById     String            @map("created_by_id")
  appointmentType AppointmentType   @default(OTHER) @map("appointment_type")
  status          AppointmentStatus @default(SCHEDULED)
  scheduledAt     DateTime          @map("scheduled_at")
  durationMinutes Int               @default(30) @map("duration_minutes")
  notes           String?           @db.Text
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  shop      Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  client    Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy User   @relation("AppointmentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([shopId])
  @@index([clientId])
  @@index([scheduledAt])
  @@index([status])
  @@map("appointments")
}

// ============================================
// PANORAMA SYSTEM
// ============================================

model PanoramaScene {
  id        String   @id @default(uuid())
  shopId    String   @map("shop_id")
  name      String   @db.VarChar(255)
  imageUrl  String   @map("image_url") @db.VarChar(500)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  shop     Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  hotspots PanoramaHotspot[]

  @@index([shopId])
  @@map("panorama_scenes")
}

model PanoramaHotspot {
  id        String  @id @default(uuid())
  shopId    String  @map("shop_id")
  sceneId   String  @map("scene_id")
  moduleKey String  @map("module_key") @db.VarChar(50)
  label     String  @db.VarChar(100)
  x         Decimal @db.Decimal(5, 4)
  y         Decimal @db.Decimal(5, 4)
  w         Decimal @db.Decimal(5, 4)
  h         Decimal @db.Decimal(5, 4)
  icon      String? @db.VarChar(100)
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  scene PanoramaScene @relation(fields: [sceneId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([sceneId])
  @@map("panorama_hotspots")
}

// ============================================
// SYSTEM ENTITIES
// ============================================

model ActivityLog {
  id         String   @id @default(uuid())
  shopId     String   @map("shop_id")
  userId     String?  @map("user_id")
  action     String   @db.VarChar(100)
  entityType String?  @map("entity_type") @db.VarChar(100)
  entityId   String?  @map("entity_id") @db.VarChar(100)
  details    Json?
  ipAddress  String?  @map("ip_address") @db.VarChar(50)
  userAgent  String?  @map("user_agent") @db.VarChar(500)
  createdAt  DateTime @default(now()) @map("created_at")

  shop Shop  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([shopId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("activity_logs")
}

model AppSetting {
  id        String   @id @default(uuid())
  shopId    String   @map("shop_id")
  key       String   @db.VarChar(100)
  value     Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, key])
  @@index([shopId])
  @@map("app_settings")
}

model PlatformSetting {
  id        String   @id @default(uuid())
  key       String   @unique @db.VarChar(100)
  value     Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("platform_settings")
}

// ============================================
// NOTIFICATIONS
// ============================================

enum NotificationType {
  APPOINTMENT_SOON
  APPOINTMENT_OVERDUE
  ORDER_READY
  ORDER_OVERDUE
  LOW_STOCK
  ATELIER_BLOCKED
  ATELIER_URGENT
}

model Notification {
  id          String           @id @default(uuid())
  shopId      String           @map("shop_id")
  userId      String?          @map("user_id")
  type        NotificationType
  title       String           @db.VarChar(255)
  message     String           @db.Text
  entityType  String?          @map("entity_type") @db.VarChar(50)
  entityId    String?          @map("entity_id")
  isRead      Boolean          @default(false) @map("is_read")
  readAt      DateTime?        @map("read_at")
  createdAt   DateTime         @default(now()) @map("created_at")

  @@index([shopId])
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}
