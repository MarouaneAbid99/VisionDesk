# VisionDesk API - Production Environment Variables
# Copy this file to .env and fill in the values

# ===========================================
# DATABASE
# ===========================================
# PlanetScale: mysql://user:pass@host/db?ssl={"rejectUnauthorized":true}
# Railway: mysql://user:pass@host:port/db
DATABASE_URL="mysql://user:password@host:3306/visiondesk"

# ===========================================
# AUTHENTICATION
# ===========================================
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-64-character-random-secret-key-generate-new-one-for-production"
JWT_EXPIRES_IN="7d"

# ===========================================
# SERVER
# ===========================================
PORT=3001
NODE_ENV=production

# ===========================================
# CORS
# ===========================================
# Comma-separated list of allowed origins
CORS_ORIGINS="https://app.visiondesk.ma,https://admin.visiondesk.ma"

# ===========================================
# FILE UPLOADS (Optional)
# ===========================================
# UPLOAD_DIR="/var/data/uploads"
# MAX_FILE_SIZE="10mb"

# ===========================================
# LOGGING (Optional)
# ===========================================
# LOG_LEVEL="info"
