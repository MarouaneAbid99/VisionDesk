# VisionDesk API - Environment Variables
# Copy this file to .env and fill in the values

# ===========================================
# DATABASE
# ===========================================
DATABASE_URL="mysql://root:@localhost:3306/visiondesk"

# ===========================================
# AUTHENTICATION
# ===========================================
# Generate secure secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# ===========================================
# SERVER
# ===========================================
PORT=3001
NODE_ENV=development

# ===========================================
# CORS (Production only)
# ===========================================
# Comma-separated list of allowed origins
# CORS_ORIGINS="https://app.visiondesk.ma,https://admin.visiondesk.ma"
